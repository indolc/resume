---
import Section from './Section.astro';
import { resume } from '../data/resume';
---

<Section id="experience" title="Experience">
  <div class="space-y-10">
    {
      resume.experience.map((job) => (
        <article class="relative">
          <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
            <h3 class="text-lg font-semibold">
              {job.role}
              <span class="text-[var(--color-muted)]"> · {job.company}</span>
            </h3>
            <p class="shrink-0 text-sm tabular-nums text-[var(--color-muted)]">
              {job.period}
            </p>
          </div>

          <p class="mt-2 text-[15px] leading-relaxed text-[var(--color-muted)]">
            {job.summary}
          </p>

          <ul class="mt-4 space-y-2">
            {job.highlights.map((h) => (
              <li class="flex gap-3 text-[15px] leading-relaxed">
                <span class="mt-2 size-1.5 shrink-0 rounded-full bg-[var(--color-accent)]" />
                <span>{h}</span>
              </li>
            ))}
          </ul>

          {job.stack && (
            <ul class="mt-4 flex flex-wrap gap-2">
              {job.stack.map((tech) => (
                <li class="rounded-md bg-[var(--color-surface)] px-2.5 py-1 text-xs font-medium text-[var(--color-muted)] ring-1 ring-[var(--color-line)]">
                  {tech}
                </li>
              ))}
            </ul>
          )}
        </article>
      ))
    }
  </div>
</Section>
